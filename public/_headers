/*
  Permissions-Policy: camera=(self), microphone=(self), accelerometer=(self), gyroscope=(self), magnetometer=(self), xr-spatial-tracking=(self)
  Referrer-Policy: strict-origin-when-cross-origin

# 8th Wall SDK は WASM/バイナリチャンクを含むので長期キャッシュを避ける
/xr/*
  Cache-Control: public, max-age=3600

/xrextras/*
  Cache-Control: public, max-age=3600

# 画像マーカー JSON は更新されたら反映されるよう短めのキャッシュ
/image-targets/*
  Cache-Control: public, max-age=300
